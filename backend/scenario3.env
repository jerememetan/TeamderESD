# Scenario 3 environment variables for swap-request-service
# Fill these values before running docker compose.

# SQLAlchemy / Supabase PostgreSQL connection string placeholder.
# Example format:
# postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>
SUPABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# RabbitMQ connection host/port used by swap_request/consumer.py
# Use rabbitmq when running inside docker compose.
rabbit_host=rabbitmq
rabbit_port=5672

# RabbitMQ exchange and queue settings used by the consumer.
exchange_name=swap_topic
exchange_type=topic
queue_name=SwapRequestStatusQueue

# Routing keys consumed by the service are hardcoded in code as:
# SwapRejected, SwapExecuted, SwapFailed
